# .env.example — DocMind-VLM Backend Configuration
# Copy to .env and fill in your values.
# All variables map to Settings fields in core/config.py

# ── App ───────────────────────────────────────────────
APP_NAME="DocMind-VLM"
APP_VERSION="0.1.0"
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8009
APP_DEBUG=true
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────
ALLOWED_ORIGINS_STR=http://localhost:5177,http://localhost:3000

# ── VLM Provider ─────────────────────────────────────
VLM_PROVIDER=dashscope

# ── DashScope (Qwen-VL) ──────────────────────────────
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_MODEL=qwen-vl-max
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
DASHSCOPE_MAX_RETRIES=3
DASHSCOPE_RETRY_DELAY=2.0
DASHSCOPE_TIMEOUT=120.0

# ── OpenAI (GPT-4o) ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Google (Gemini) ───────────────────────────────────
GOOGLE_API_KEY=AI...
GOOGLE_MODEL=gemini-2.0-flash

# ── Ollama (local) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# ── Supabase (Auth + Storage) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
STORAGE_BUCKET=documents

# ── Database (Supabase Postgres via SQLAlchemy) ──────
DB_HOST=db.[project-ref].supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=postgres

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Data / Storage ────────────────────────────────────
DATA_DIR=data

# ── Upload Limits ─────────────────────────────────────
MAX_UPLOAD_SIZE=20971520
MAX_FILENAME_LENGTH=255

# ── CV Preprocessing ─────────────────────────────────
CV_MAX_DIMENSION=4096
CV_TARGET_DPI=300

# ── Pipeline Confidence ──────────────────────────────
CONFIDENCE_VLM_WEIGHT=0.7
CONFIDENCE_CV_WEIGHT=0.3
CONFIDENCE_LOW_THRESHOLD=0.5

# ── Chat Pipeline ────────────────────────────────────
CHAT_MAX_PAGE_IMAGES=4
CHAT_MAX_HISTORY=6
CHAT_MAX_REQUERY_FIELDS=3
CHAT_LOW_CONFIDENCE=0.6

# ── Encryption ───────────────────────────────────────
# Fernet key for encrypting user API keys (BYOK feature).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── SSE ───────────────────────────────────────────────
SSE_HEARTBEAT_TIMEOUT=30.0
